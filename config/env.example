#
# Environment configuration for FinSense (Python 3.10+)
# Copy this file to `.env` and update the values.
#

# Core paths
PROJECT_ROOT=.
DATA_DIR=./data
MODELS_DIR=./models
LOGS_DIR=./logs

# API keys
OPENAI_API_KEY=your-openai-api-key
GROQ_API_KEY=your-groq-api-key
LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_MODEL=gpt-4o-mini
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Model files (optional overrides)
ML_MODEL_PATH=./models/ml/latest_model.pkl
LSTM_MODEL_PATH=./models/lstm/latest_model.h5

# Dashboard/Backend
STREAMLIT_PORT=8501
BACKEND_PORT=8000














